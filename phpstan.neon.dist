parameters:
    level: 10
    treatPhpDocTypesAsCertain: false
    paths:
        - src
        - cli
    tmpDir: .phpstan
    scanFiles:
        - phpstan/stubs/wp-config.php
        - phpstan/stubs/wordpress.php
        - phpstan/stubs/wp-cli.php
    ignoreErrors:
        -
            identifier: trait.unused
        -
            identifier: constructor.unusedParameter
            path: src/Worker.php
